<h1 class= "choose-card">Choose a game</h1>

<%= image_tag "https://www.pokemon.co.jp/ex/VCAMAP/game/images/ss_12.jpg", alt: "ポケモンバージョン", class: "poke-logo" %>
<%= form_with model: @playthrough do |f| %>

<div class="cards">

  <div class="card">
    <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/1.png">
    <p>Bulbasaur</p>
  </div>

  <div class="card">
    <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/4.png">
    <p>Charmander</p>
  </div>

</div>

<br>

<%= f.label :game_version %>

<%= f.select :game_version,
      Playthrough::GAME_VERSIONS.map { |v| [v.titleize, v] } %>

<br><br>

<div class="d-flex justify-content-center mt-4">
  <%= f.submit "Next", class: "pokemon-btn" %>
</div>

<% end %>
