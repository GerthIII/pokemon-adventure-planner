<div class="container mt-3">
  <h1>Team: <%= @team.name %></h1>
  <div class="row row-cols-1 row-cols-md-3 g-4">
    <% @team.team_members.each do |member| %>
      <div class="col">
        <div class="card shadow-sm justify-content-center">
          <%= image_tag member.pokemon.image_url, class: "card-img-top mx-auto d-block", alt: member.pokemon.name %>

          <div class="card-body text-center">
            <h2 class="card-title fw-bold mb-2">
              <%= member.pokemon.name.capitalize %>
            </h2>

            <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
              <span class="badge rounded-pill bg-danger">Ab: <%= member.ability %></span>
              <span class="badge rounded-pill bg-success">Nt: <%= member.nature %></span>
              <span class="badge rounded-pill bg-warning text-dark">It: <%= member.held_item %></span>
            </div>

            <hr>

            <h5 class="fw-semibold mb-2">Move Set</h5>
            <ul class="list-unstyled text-start small mb-0">
              <li><%= member.move_1 %></li>
              <li><%= member.move_2 %></li>
              <li><%= member.move_3 %></li>
              <li><%= member.move_4 %></li>
            </ul>

            <hr>

            <p class="card-text text-muted mb-3">
              Is a good choice because - <%= member.progression_strategy %>
            </p>
          </div><%# end card-body %>
        </div><%# end card %>
      </div><%# end col %>
    <% end %>
  </div><%# end row %>

  <%= link_to "My Teams", playthrough_teams_path(@playthrough), class: "btn btn-info fw-bold rounded-pill shadow-sm btn-lg my-5" %>

 <div class="container mb-3">
  <div class="row">
    <!-- LEFT -->
    <div class="col-6">
      <div class="card shadow-sm p-3 d-flex flex-column justify-content-start text-start">
        <h2>Game Progression</h2>
        <hr>

        <% @team.team_members.each do |member| %>
          <h3 class="mb-1"><strong><%= member.pokemon.name.capitalize %></strong></h3>
          <p class="mb-3"><%= member.walkthrough %></p>
        <% end %>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="col-6 d-flex align-items-center justify-content-center">
      <%= image_tag "pokemongif.gif", class: "img-fluid", alt: "Pokemon gif" %>
    </div>
  </div>
</div>

</div><%# end container %>
