<div class="container mt-3">
  <h1>Team: <%= @team.name %></h1>
  <div class="row row-cols-1 row-cols-md-3 g-4">
    <% @team.team_members.each do |member| %>
      <div class="col">
        <div class="card shadow-sm d-flex justify-content-center align-items-center">
          <%= image_tag member.pokemon.image_url, class: "card-img-top", alt: member.pokemon.name %>

          <div class="card-body text-center">
            <h2 class="card-title fw-bold mb-2">
              <%= member.pokemon.name.capitalize %>
            </h2>

            <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
              <span class="badge rounded-pill bg-danger">Ability: <%= member.ability %></span>
              <span class="badge rounded-pill bg-success">Nature: <%= member.nature %></span>
              <span class="badge rounded-pill bg-warning text-dark">Item: <%= member.held_item %></span>
            </div>

            <hr>

            <h5 class="fw-semibold mb-2">Move Set</h5>
            <ul class="list-unstyled text-start small mb-0">
              <li><%= member.move_1 %></li>
              <li><%= member.move_2 %></li>
              <li><%= member.move_3 %></li>
              <li><%= member.move_4 %></li>
            </ul>

            <hr>

            <p class="card-text text-muted mb-3">
              Is a good choice because - <%= member.progression_strategy %>
            </p>
          </div><%# end card-body %>
        </div><%# end card %>
      </div><%# end col %>
    <% end %>
  </div><%# end row %>

  <%= link_to "My Teams", playthrough_teams_path(@playthrough), class: "btn btn-info fw-bold rounded-pill shadow-sm my-3" %>
</div><%# end container %>
