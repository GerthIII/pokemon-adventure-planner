<div class="container mt-5">
  <h1>Playthrough: <%= @playthrough.game_version.capitalize %></h1>
  <hr class="border-light">
  <h3>My Teams</h3>
  <div class="list-group">
    <% @playthrough.teams.each do |team| %>
      <%# link_to generates the <a> tag to your team show page %>
      <%= link_to team_path(team), class: "list-group-item list-group-item-action bg-dark text-light border-secondary d-flex justify-content-between align-items-center mb-2 rounded shadow-sm" do %>
        <div>
          <strong class="fs-5 text-info"><%= team.name %></strong>
          <span class="ms-3 text-muted">
            <%= team.team_members.count %> Pokémon
          </span>
        </div>
        <i class="fa-solid fa-chevron-right text-muted"></i>
      <% end %>
    <% end %>
  </div>
  <%# Button to start a brand new team for this specific playthrough %>
  <div class="mt-4">
    <%= link_to "Create New Team", new_playthrough_team_path(@playthrough), class: "btn btn-info fw-bold rounded-pill" %>
  </div>
</div>
