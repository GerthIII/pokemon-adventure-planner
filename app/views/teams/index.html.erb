<div class="container mt-4">
  <div class="row row-cols-1 row-cols-md-4 g-4 justify-content-center"> <% @teams.each do |team| %>
      <div class="col d-flex justify-content-center"> <%= link_to edit_team_path(team), class: "text-decoration-none text-dark" do %>
          <div class="card h-100 shadow-sm hover-shadow border-3 border-dark" style="width: 18rem;">
            <div class="card-body text-center">
              <h5 class="card-title fw-bold"><%= team.name %></h5>
              <h6 class="card-subtitle mb-2 text-muted"><%= team.playthrough.game_version.capitalize %> Version Playthrough</h6>
              <div class="row row-cols-3 g-1 mt-2"> <% team.pokemons.each do |pokemon| %>
                  <div class="col text-center">
                    <%= image_tag pokemon.image_url, 
                    alt: pokemon.name, 
                    class: "img-fluid", 
                    style: "max-height: 45px; width: auto;" %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<div class="new-team-button mt-3">
  <%= link_to "Create a new Team", new_playthrough_team_path(@playthrough), class: "btn btn-info fw-bold rounded-pill shadow-sm" %>
</div>