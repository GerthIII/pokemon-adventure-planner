<div class="container" data-controller="get-pokemon">
  <h1 class="title text-center mb-4">Edit Your Team: <%= @team.name %></h1>

  <%= simple_form_for @team do |f| %>
    <div class="row g-3 justify-content-center">
      <% 6.times do |i| %>
        <% current_member_id = @team.team_members[i]&.pokemon&.id || "" %>

        <div class="col-12 col-md-4">
          <label class="fw-bold text-light d-block mb-1">Slot <%= i + 1 %></label>

          <%= select_tag "team[pokemon_ids][]",
            options_from_collection_for_select(@available_pokemon, :id, :name, current_member_id),
            include_blank: "Leave blank for AI recommendation",
            class: "form-select rounded-pill shadow-sm",
            data: {
              get_pokemon_target: "slot",
              slot_index: i,
              action: "change->get-pokemon#capture"
            } %>
        </div>
      <% end %>
    </div>

    <div class="d-flex justify-content-center mt-4">
      <%= f.submit "Update Team",
        class: "pokemon-btn",
        style: "width:260px;height:48px;display:inline-flex;align-items:center;justify-content:center;" %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= simple_form_for [@team, Message.new] do |m| %>
      <%= m.input :content,
        as: :text,
        label: "Ask the AI for Advice",
        placeholder: "e.g. Create a Fire Type Team",
        input_html: { class: "form-control", rows: 3, data: { team_builder_target: "question" } } %>

      <%= m.hidden_field :role, value: "user" %>
      <%= hidden_field_tag "message[team_context]", "", data: { get_pokemon_target: "teamContext" } %>

      <div class="d-flex justify-content-center mt-3">
        <%= m.submit "Build a Team For Me",
          class: "pokemon-btn",
          data: { action: "click->get-pokemon#inject" },
          style: "width:260px;height:48px;display:inline-flex;align-items:center;justify-content:center;" %>
      </div>
    <% end %>

    <div class="d-flex justify-content-center mt-3 mb-5">
      <%= link_to "Back",
        playthrough_teams_path(@playthrough),
        class: "pokemon-btn",
        style: "width:260px;height:48px;display:inline-flex;align-items:center;justify-content:center;background:black" %>
    </div>
  </div>
</div>
