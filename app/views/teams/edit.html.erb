<div class="container mt-5">
  <h1>Edit Your Team: <%= @team.name %></h1>
  <%= simple_form_for @team do |f| %>
    <div class="row">
      <% members = @team.team_members.all %>
      <% 6.times do |i| %>
        <% current_member = members[i] %>
        <div class="col-md-4 mb-3">
          <label class="fw-bold text-light">Slot <%= i + 1 %></label>
          <%= f.input :pokemon_ids, 
                      collection: @available_pokemon, 
                      label: false, 
                      prompt: "Select a Pokemon",
                      include_blank: "Leave blank for AI recommendation",
                      selected: current_member&.pokemon_id,
                      input_html: { name: "team[pokemon_ids][]", class: "rounded-pill shadow-sm" } %>
        </div>
      <% end %>
    </div>
    <%# Use fields_for to target the Message model %>
    <%= f.simple_fields_for :messages, @team.messages.build do |m| %>
      <%= m.input :content, 
                as: :text, 
                label: "Ask the AI for Advice", 
                placeholder: "e.g. Can I get a Scizor before the Elite Four?" %>
      <%= m.hidden_field :role, value: "user" %>
    <% end %>
    <%= f.submit "Update Team", class: "btn btn-primary" %>
  <% end %>
</div>