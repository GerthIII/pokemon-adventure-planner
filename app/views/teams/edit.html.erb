<div class="container">
  <h1>Edit Your Team: <%= @team.name %></h1>

  <!-- TEAM UPDATE FORM -->
  <%= simple_form_for @team do |f| %>
    <div class="row">
      <% members = @team.team_members.all %>
      <% 6.times do |i| %>
        <% current_member = members[i] %>

        <div class="col-md-4 mb-3">
          <label class="fw-bold text-light">Slot <%= i + 1 %></label>

           <%= select_tag "team[pokemon_ids][]",
            options_from_collection_for_select(
              @available_pokemon, :id, :name, current_member&.pokemon_id
            ),
            include_blank: "Leave blank for AI recommendation",
            class: "form-select rounded-pill shadow-sm" %>
        </div>
      <% end %>
    </div>

    <div class="d-flex justify-content-center mt-4">
      <%= f.submit "Update Team",
            class: "btn btn-primary fw-bold rounded-pill px-5 py-2" %>
    </div>
  <% end %>

  <!-- AI MESSAGE FORM -->
  <div class="mt-4">
    <%= simple_form_for [@team, Message.new] do |m| %>
      <%= m.input :content,
            as: :text,
            label: "Ask the AI for Advice",
            placeholder: "e.g. Can I get a Scizor before the Elite Four?" %>

      <%= m.hidden_field :role, value: "user" %>

      <div class="d-flex justify-content-center">
        <%= m.submit "Ask AI", class: "btn btn-primary fw-bold rounded-pill px-5 py-2" %>
      </div>
    <% end %>
  </div>
</div>
